  "insights": {
    "sections": [
      {
        "heading": "Support for physical punishment increased",
        "body": "In 2025, 18.3 percent of mothers and caretakers believed that a child needs to be physically punished, up from 11.9 percent in 2022. This page measures attitudes, not direct disciplining behavior, but the increase is large enough to be the main national finding."
      },
      {
        "heading": "CAR is the clearest regional outlier",
        "body": "CAR had the highest share of respondents who believe physical punishment is needed, at 42.6 percent. Northern Mindanao followed at 36.6 percent, and Davao Region was third at 29.0 percent. These levels are far above the national average of 18.3 percent."
      },
      {
        "heading": "Some regions remain below 10 percent",
        "body": "Central Visayas had the lowest level at 7.7 percent, followed by Ilocos Region at 8.0 percent. Cagayan Valley was also relatively low at 11.3 percent. The gap between CAR and Central Visayas is 34.9 points, so regional variation dominates this page."
      },
      {
        "heading": "Attitudes and reported discipline do not map perfectly",
        "body": "Some regions with high reported violent discipline are also high in attitudes toward physical punishment, but the pattern is not identical. Davao Region is high on both, while CAR is highest on attitudes without being the highest on violent discipline. The attitude measure should therefore be read as related context, not as a direct substitute for behavior."
      },
      {
        "heading": "The national increase is not a small technical change",
        "body": "The national value rose by 6.4 points between 2022 and 2025. Because the indicator is a belief measure, the increase should be described carefully, but it is still substantial in relative terms. It suggests that the 2025 attitude profile is meaningfully different from the 2022 profile."
      }
    ],
    "takeaways": [
      "The share of mothers and caretakers who believe physical punishment is needed rose from 11.9 percent in 2022 to 18.3 percent in 2025.",
      "CAR and Northern Mindanao are the highest regions on this attitude measure.",
      "Regional variation is large, with Central Visayas and Ilocos Region below 10 percent."
    ]
  }
}
