  "insights": {
    "sections": [
      {
        "heading": "Polio coverage improved, but later doses remain lower",
        "body": "OPV 1 reached 93.0 percent in 2025, compared with 83.0 percent for OPV 3. IPV 1 was 89.1 percent and IPV 2 was 78.9 percent. The sequence shows high initial reach but lower completion at later doses."
      },
      {
        "heading": "Polio 3 rose sharply from 2022",
        "body": "Polio 3 coverage increased from 71.5 percent in 2022 to 83.3 percent in 2025. OPV 1, OPV 2, OPV 3, and IPV 1 also improved. IPV 2 was lower in 2025 than in 2022, at 78.9 percent compared with 81.8 percent, so the improvement is not uniform across every polio-related measure."
      },
      {
        "heading": "BARMM has the steepest dose drop-off",
        "body": "BARMM had 63.3 percent OPV 1 coverage but only 29.7 percent OPV 3 and 30.2 percent IPV 2. This is the lowest regional level for the later-dose measures and suggests that completion is the main issue in the regional polio profile, not only first contact with vaccination."
      },
      {
        "heading": "Ilocos Region is consistently high across the polio sequence",
        "body": "Ilocos Region recorded 100.0 percent OPV 1, 97.7 percent OPV 3, and 97.5 percent IPV 2. It also leads Polio 3 coverage. The small gap between early and later polio measures in Ilocos contrasts sharply with the large gap in BARMM."
      },
      {
        "heading": "Regional patterns diverge more at later doses",
        "body": "Early-dose OPV coverage is high in many regions, but later-dose indicators reveal sharper separation. Zamboanga Peninsula had 77.6 percent OPV 1, 66.3 percent OPV 3, and 61.3 percent IPV 2. Northern Mindanao was not among the lowest for OPV 1 but was low for IPV 2 at 54.2 percent, showing that OPV and IPV completion patterns do not always move together."
      }
    ],
    "takeaways": [
      "Polio 3 coverage rose from 71.5 percent in 2022 to 83.3 percent in 2025.",
      "Later-dose polio indicators remain lower than first-dose coverage nationally.",
      "BARMM has the largest regional completion gap, while Ilocos Region is consistently high across the sequence."
    ]
  }
}
