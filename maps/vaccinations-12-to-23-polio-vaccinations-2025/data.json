{
  "sectionTitle": "VACCINATIONS",
  "title": "Children Aged 12 to 23 Months - Polio Vaccinations",
  "description": "Percentage of children aged 12 to 23 months who received scheduled polio vaccines at any time before the survey (according to a vaccination card or the mother's report). Source: Philippine Statistics Authority, 2025 National Demographic and Health Survey.",
  "notes": {
    "opv_1": "OPV = Oral polio vaccine.",
    "opv_2": "OPV = Oral polio vaccine.",
    "opv_3": "OPV = Oral polio vaccine.",
    "ipv_1": "IPV = Inactivated polio vaccine.",
    "ipv_2": "IPV = Inactivated polio vaccine.",
    "polio_3": "Polio 3 indicates receipt of three doses of polio vaccine (OPV and/or IPV). OPV = Oral polio vaccine. IPV = Inactivated polio vaccine."
  },
  "note": "Children are considered to have received the vaccine if it was either written on the child's vaccination card or reported by the mother. Figures in parentheses are based on 25-49 unweighted cases.",
