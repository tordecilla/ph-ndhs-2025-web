  "notes": {
    "fully_vaccinated_basic_antigens": "BCG = Bacille Calmette-Guerin; DPT = Diphtheria-pertussis-tetanus; OPV = Oral polio vaccine; IPV = Inactivated polio vaccine; MMR = Measles, mumps, rubella.",
